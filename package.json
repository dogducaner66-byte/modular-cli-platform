{
  "name": "modular-cli-platform",
  "version": "1.0.0",
  "description": "A modular TypeScript CLI platform with filesystem-discovered commands and plugin loading.",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "modular-cli-platform": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "default": "./dist/loader.js"
    },
    "./output": {
      "types": "./dist/output.d.ts",
      "default": "./dist/output.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "default": "./dist/registry.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "modular",
    "plugin",
    "typescript"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && node scripts/add-shebang.mjs",
    "start": "node dist/cli.js",
    "dev": "node --import tsx src/cli.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run",
    "verify:commands": "node dist/cli.js version && node dist/cli.js list && node dist/cli.js help doctor && node dist/cli.js doctor && node dist/cli.js info"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "ora": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.7.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4"
  }
}
